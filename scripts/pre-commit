#!/usr/bin/env bash
#
# Pre-commit hook. Mirrors the checks run by .forgejo/workflows/check.yml so
# CI failures get caught before push instead of after. Install with
# `just install-hooks`. Bypass for a single commit with `git commit --no-verify`.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

run() {
    printf '\n[pre-commit] %s\n' "$*"
    "$@"
}

run cargo fmt --check
run cargo clippy --all-targets -- -D warnings
run cargo check --features standalone,web --target wasm32-unknown-unknown
run cargo check --no-default-features --features saas,web --target wasm32-unknown-unknown
run cargo build --all-targets
run cargo test --lib

printf '\n[pre-commit] all checks passed\n'
