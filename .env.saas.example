###############################################################################
# ---- Hosted (OIDC) Mode Configuration ----
###############################################################################
# A single binary/image serves both deployment modes; the mode is resolved at
# runtime from OIDC_ISSUER. Setting OIDC_ISSUER (below) switches this instance
# into hosted mode: OIDC login against a8n Tools, with an active membership
# required to use the system. Leaving OIDC_ISSUER unset runs standalone mode
# (local JWT auth — see .env.standalone.example).
#
# Build with: cargo build --release --features server   (dx build for fullstack)
# Docker:     docker build -t rusty-links .

# =============================================================================
# Hosted Authentication (OIDC)
# =============================================================================
# rusty-links acts as an OIDC Relying Party (BFF) and Resource Server against
# the a8n Tools identity provider. Membership enforcement (has_member_access)
# is applied at the OIDC JIT layer.

# Required (hosted mode switch): OIDC issuer URL. Set = hosted mode, unset = standalone.
OIDC_ISSUER=https://a8n.tools

# Required in hosted mode: OAuth2 client credentials registered with the provider.
# OIDC_CLIENT_SECRET may instead be supplied via /run/secrets/oidc_client_secret.
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here

# Optional: expected `aud` in at+jwt access tokens (default: https://links.a8n.run/api)
# OIDC_AUDIENCE=https://links.a8n.run/api

# Optional: JWKS endpoint (default: derived from OIDC_ISSUER as <issuer>/.well-known/jwks.json)
# OIDC_JWKS_URL=https://a8n.tools/.well-known/jwks.json

# Optional: JWKS in-memory cache TTL in seconds (default: 300)
# OIDC_JWKS_CACHE_TTL=300

# Optional: redirect URI registered with the provider (default: <HOST_URL>/oauth2/callback)
# OIDC_REDIRECT_URI=https://links.example.com/oauth2/callback

# Optional: post-logout redirect URI (default: <HOST_URL>/)
# OIDC_POST_LOGOUT_REDIRECT_URI=https://links.example.com/

# Optional: token validation clock-skew leeway in seconds (default: 30)
# OIDC_LEEWAY_SECONDS=30

# Optional: JTI idempotency cache TTL for lifecycle/logout events in seconds (default: 300)
# OIDC_LIFECYCLE_JTI_CACHE_TTL=300

# Optional: BFF rl_session cookie lifetime in seconds (default: 1209600 = 14 days)
# OIDC_SESSION_TTL_SECONDS=1209600

# Required: Public URL of this rusty-links instance (used to build OIDC redirect URLs)
# Example: https://links.example.com
HOST_URL=https://links.example.com

# Optional: shared secret for validating maintenance-webhook signatures
# WARNING: If not set, webhook signatures will NOT be validated
# WEBHOOK_SECRET=your_webhook_secret_here

###############################################################################
# ---- Shared Configuration ----
###############################################################################

# =============================================================================
# Database (shared by postgres + api services)
# =============================================================================
# For local development (no Docker):
DATABASE_URL=postgresql://user:password@localhost/rusty_links

# For Docker Compose (DATABASE_URL is automatically set in compose.yml):
DB_USERNAME=rustylinks
DB_PASSWORD=changeme_secure_password_here
DB_NAME=rustylinks

# =============================================================================
# Application
# =============================================================================
# Optional: IP address to bind the server to (default: 0.0.0.0)
# Also used as the host-side bind address in Docker Compose port mappings.
# HOST_IP=0.0.0.0

# Required: Port number for the web server (1-65535)
# Read by dioxus-cli-config's server_port() as a fallback when not running under `dx serve`.
APP_PORT=4002

# Optional: Host port mapping for Docker (default: 4002, useful for running multiple instances)
# HOST_PORT=4002

# =============================================================================
# Scheduler
# =============================================================================
# Optional: Number of days between automatic metadata updates (default: 30, minimum: 1)
# WARNING: Setting this too low may exceed GitHub API rate limits
# UPDATE_INTERVAL_DAYS=30

# Optional: How often to run the update scheduler in hours (default: 24, minimum: 1)
# UPDATE_INTERVAL_HOURS=24

# Optional: Batch size for processing updates (default: 50, minimum: 1)
# BATCH_SIZE=50

# Optional: Jitter percentage for update scheduling (default: 20, range: 0-100)
# JITTER_PERCENT=20

# =============================================================================
# External Services
# =============================================================================
# Optional: GitHub token for higher API rate limits (60/hr without, 5000/hr with)
# Get one at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# Logging
# =============================================================================
# Optional: Logging level (default: info)
# Valid values: trace, debug, info, warn, error
# RUST_LOG=info

# Optional: Enable backtraces in development
# RUST_BACKTRACE=1
